# ForgeOS Pi + RunPod vLLM environment

# RunPod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_OPENAI_BASE_URL=https://api.runpod.ai/v2/${RUNPOD_ENDPOINT_ID}/openai/v1

# Model served by vLLM on RunPod
RUNPOD_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ForgeOS
FORGEOS_PROJECT_ROOT=${PWD}
FORGEOS_TOOL_GATEWAY_URL=http://127.0.0.1:8787
FORGEOS_AGENT_PROFILE=pi-runpod-vllm

# Safety / execution
FORGEOS_REQUIRE_CONTRACTS=true
FORGEOS_ALLOW_SHELL=false
FORGEOS_LOG_DIR=.forgeos/logs
