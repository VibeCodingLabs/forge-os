[Unit]
Description=ForgeOS observer — deep system snapshot
Documentation=https://github.com/VibeCodingLabs/forge-os
After=default.target

[Service]
Type=oneshot
ExecStart=%h/.local/bin/forge-observer
StandardOutput=append:%h/.forge-os/logs/observer-svc.log
StandardError=append:%h/.forge-os/logs/observer-svc.log
Environment=FORGE_HOME=%h/.forge-os
TimeoutStartSec=60

[Install]
WantedBy=default.target
