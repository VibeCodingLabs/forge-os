#!/usr/bin/env sh
# ForgeOS River command center config
# Copy target: ~/.config/river/init

export XDG_CURRENT_DESKTOP=river
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=river
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export GDK_BACKEND=wayland
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24

MOD=Super

# Layout
if command -v rivertile >/dev/null 2>&1; then
  riverctl default-layout rivertile
  rivertile -view-padding 6 -outer-padding 8 -main-ratio 0.55 >/tmp/forge-rivertile.log 2>&1 &
fi

# Autostart services
command -v mako >/dev/null 2>&1 && mako >/tmp/forge-mako.log 2>&1 &
command -v waybar >/dev/null 2>&1 && waybar >/tmp/forge-waybar.log 2>&1 &
command -v eww >/dev/null 2>&1 && eww daemon >/tmp/forge-eww.log 2>&1 &
command -v swww-daemon >/dev/null 2>&1 && swww-daemon >/tmp/forge-swww.log 2>&1 &
command -v wl-paste >/dev/null 2>&1 && command -v cliphist >/dev/null 2>&1 && wl-paste --type text --watch cliphist store >/tmp/forge-cliphist.log 2>&1 &
command -v wl-paste >/dev/null 2>&1 && command -v cliphist >/dev/null 2>&1 && wl-paste --type image --watch cliphist store >/tmp/forge-cliphist-image.log 2>&1 &
command -v dbus-update-activation-environment >/dev/null 2>&1 && dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE &
command -v forge-wallpaper >/dev/null 2>&1 && forge-wallpaper >/tmp/forge-wallpaper.log 2>&1 &
systemctl --user start forge-heartbeat.timer forge-observer.timer 2>/dev/null || true

# Core apps
if command -v kitty >/dev/null 2>&1; then
  riverctl map normal "$MOD" Return spawn kitty
elif command -v wezterm >/dev/null 2>&1; then
  riverctl map normal "$MOD" Return spawn wezterm
else
  riverctl map normal "$MOD" Return spawn foot
fi

command -v wofi >/dev/null 2>&1 && riverctl map normal "$MOD" D spawn 'wofi --show drun'
command -v fuzzel >/dev/null 2>&1 && riverctl map normal "$MOD" Space spawn fuzzel
command -v firefox-esr >/dev/null 2>&1 && riverctl map normal "$MOD" B spawn firefox-esr
command -v chromium >/dev/null 2>&1 && riverctl map normal "$MOD+Shift" B spawn chromium
command -v yazi >/dev/null 2>&1 && riverctl map normal "$MOD" E spawn 'kitty -e yazi'

# Forge launchers
riverctl map normal "$MOD" A spawn 'kitty --title agent-workspace tmux new-session -A -s forge-agents'
riverctl map normal "$MOD" O spawn 'kitty --title observability btop'
riverctl map normal "$MOD" G spawn 'kitty --title git lazygit'
riverctl map normal "$MOD" W spawn 'forge-wallpaper'
riverctl map normal "$MOD+Shift" D spawn 'forge-dictation-note'

# Screenshots and clipboard
command -v grim >/dev/null 2>&1 && command -v slurp >/dev/null 2>&1 && riverctl map normal "$MOD" S spawn 'grim -g "$(slurp)" ~/forge-os/downloads/screenshot-$(date +%Y%m%d-%H%M%S).png'
command -v grim >/dev/null 2>&1 && riverctl map normal "$MOD+Shift" S spawn 'grim ~/forge-os/downloads/screenshot-$(date +%Y%m%d-%H%M%S).png'
command -v cliphist >/dev/null 2>&1 && command -v wofi >/dev/null 2>&1 && riverctl map normal "$MOD" V spawn 'cliphist list | wofi --dmenu | cliphist decode | wl-copy'

# Window management
riverctl map normal "$MOD+Shift" Q close
riverctl map normal "$MOD+Shift" E spawn 'riverctl exit'
riverctl map normal "$MOD" J focus-view next
riverctl map normal "$MOD" K focus-view previous
riverctl map normal "$MOD+Shift" J swap next
riverctl map normal "$MOD+Shift" K swap previous
riverctl map normal "$MOD" Period focus-output next
riverctl map normal "$MOD" Comma focus-output previous
riverctl map normal "$MOD+Shift" Period send-to-output next
riverctl map normal "$MOD+Shift" Comma send-to-output previous
riverctl map normal "$MOD" Plus send-layout-cmd rivertile 'main-count +1'
riverctl map normal "$MOD" Minus send-layout-cmd rivertile 'main-count -1'
riverctl map normal "$MOD+Alt" H send-layout-cmd rivertile 'main-ratio -0.05'
riverctl map normal "$MOD+Alt" L send-layout-cmd rivertile 'main-ratio +0.05'
riverctl map normal "$MOD+Shift" Space toggle-float
riverctl map normal "$MOD" F toggle-fullscreen
riverctl map normal "$MOD+Shift" R spawn '$HOME/.config/river/init'

riverctl map-pointer normal "$MOD" BTN_LEFT move-view
riverctl map-pointer normal "$MOD" BTN_RIGHT resize-view
riverctl map-pointer normal "$MOD" BTN_MIDDLE toggle-float

# Tags/workspaces 1-9
for i in $(seq 1 9); do
  tags=$((1 << (i - 1)))
  riverctl map normal "$MOD" "$i" set-focused-tags "$tags"
  riverctl map normal "$MOD+Shift" "$i" set-view-tags "$tags"
  riverctl map normal "$MOD+Control" "$i" toggle-focused-tags "$tags"
  riverctl map normal "$MOD+Shift+Control" "$i" toggle-view-tags "$tags"
done
all_tags=$(((1 << 32) - 1))
riverctl map normal "$MOD" 0 set-focused-tags "$all_tags"
riverctl map normal "$MOD+Shift" 0 set-view-tags "$all_tags"

# Media keys
for mode in normal locked; do
  riverctl map "$mode" None XF86AudioRaiseVolume  spawn 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+'
  riverctl map "$mode" None XF86AudioLowerVolume  spawn 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-'
  riverctl map "$mode" None XF86AudioMute         spawn 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle'
  riverctl map "$mode" None XF86AudioMicMute      spawn 'wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle'
  riverctl map "$mode" None XF86MonBrightnessUp   spawn 'brightnessctl set 5%+'
  riverctl map "$mode" None XF86MonBrightnessDown spawn 'brightnessctl set 5%-'
  riverctl map "$mode" None XF86AudioPlay         spawn 'playerctl play-pause'
  riverctl map "$mode" None XF86AudioNext         spawn 'playerctl next'
  riverctl map "$mode" None XF86AudioPrev         spawn 'playerctl previous'
done

riverctl set-repeat 50 300
riverctl border-width 2
riverctl border-color-focused 0xffd08770
riverctl border-color-unfocused 0xff3b4252
riverctl border-color-urgent 0xffbf616a

# Floating rules
for app_id in pavucontrol nm-connection-editor blueman-manager gnome-calculator org.gnome.Calculator forge-command-center; do
  riverctl rule-add -app-id "$app_id" float
done
for title in Preferences Settings 'Open File' 'Save File' About observability agent-workspace; do
  riverctl rule-add -title "$title" float
 done

# Observability hook
RIVER_LOG_DIR="${FORGE_HOME:-$HOME/.forge-os}/logs/river"
mkdir -p "$RIVER_LOG_DIR"
printf '[%s] River session started | display=%s | user=%s\n' "$(date -Iseconds)" "${WAYLAND_DISPLAY:-unknown}" "$(id -un)" >> "$RIVER_LOG_DIR/session.log"
