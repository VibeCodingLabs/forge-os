# ════════════════════════════════════════════════════════════════════════════
JIRA_API_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=


# ════════════════════════════════════════════════════════════════════════════
# YOUTUBE DATA API                         sign-up: https://console.cloud.google.com/apis/credentials
# ════════════════════════════════════════════════════════════════════════════
YOUTUBE_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
# OPENWEATHER                              sign-up: https://home.openweathermap.org/api_keys
# ════════════════════════════════════════════════════════════════════════════
OPENWEATHER_API_KEY=



# =============================================================================
#  ForgeOS-specific (non-secret config)
# =============================================================================
FORGE_OS_PROFILE=hp14
FORGE_OS_LOG_DIR=$HOME/.forge-os/logs
FORGE_OS_DATA_DIR=$HOME/.forge-os/data
FORGE_OS_DEFAULT_ENHANCE_PROVIDER=groq
