GEMINI_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
# Vertex AI variant (production GCP):     sign-up: https://console.cloud.google.com/vertex-ai
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_LOCATION=us-central1


